{
  "name": "n8n-nodes-runpod",
  "version": "1.0.0",
  "description": "n8n community node to connect RunPod Serverless LLM endpoints to Basic LLM Chain and AI Agent",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "runpod",
    "llm",
    "ai",
    "language-model"
  ],
  "license": "MIT",
  "homepage": "https://github.com/cloud-assa/n8n-nodes-runpod",
  "author": {
    "name": "cloud-assa"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cloud-assa/n8n-nodes-runpod.git"
  },
  "main": "dist/nodes/RunPodChatModel/RunPodChatModel.node.js",
  "scripts": {
    "build": "tsc && node -e \"require('fs').copyFileSync('nodes/RunPodChatModel/runpod.svg','dist/nodes/RunPodChatModel/runpod.svg')\"",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/RunPodApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/RunPodChatModel/RunPodChatModel.node.js"
    ]
  },
  "dependencies": {
    "@langchain/core": ">=0.1.0"
  },
  "peerDependencies": {
    "n8n-workflow": ">=1.0.0"
  },
  "devDependencies": {
    "n8n-workflow": "^1.0.0",
    "typescript": "^5.0.0"
  }
}
